# ClinicalTrials Search Skill - 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# 在 config/genes.yaml 的 llm.provider 中选择使用哪个 provider

# ============================================================
# Provider 1: custom（自定义 OpenAI 兼容 API）
# 适用于自建网关、中转站等
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=http://your-gateway:port/v1
LLM_MODEL=glm-5.4-mini

# ============================================================
# Provider 2: stepfun（阶跃星辰）
# ============================================================
STEP_API_KEY=
STEP_BASE_URL=https://api.stepfun.com/step_plan/v1
STEP_MODEL=step-3.7-flash

# ============================================================
# Provider 3: dashscope（通义千问）
# ============================================================
DASHSCOPE_API_KEY=
DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo

# ============================================================
# 在 config/genes.yaml 中切换 provider:
#   llm:
#     provider: custom      # 使用上面的 LLM_* 变量
#     provider: stepfun     # 使用上面的 STEP_* 变量
#     provider: dashscope   # 使用上面的 DASHSCOPE_* 变量
# ============================================================
